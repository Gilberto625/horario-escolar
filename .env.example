# PostgreSQL Neon (requerido)
# Copia SOLO la URL, sin "psql", sin comillas y sin espacios extra.
# Correcto:
# DATABASE_URL=postgresql://usuario:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Incorrecto:
# DATABASE_URL=psql 'postgresql://...'
DATABASE_URL=
# Zona horaria para calcular hoy/mañana
TIMEZONE=America/Mexico_City

# CORS (separar múltiples orígenes con coma)
CORS_ORIGINS=*

# Puerto local (opcional)
PORT=8000
